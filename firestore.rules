rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // SECURITY HARDENED RULES v2 (AMG Hub launch)
    //
    // DEPLOY ORDER MATTERS — see docs/AMG_HUB_LAUNCH.md:
    //   1. Enable Anonymous auth provider (Firebase console)
    //   2. Deploy the new pages (they bootstrap anon sessions + classCodes)
    //   3. Run tools/migrate-classcodes.mjs (backfills /classCodes)
    //   4. THEN: firebase deploy --only firestore:rules
    //
    // v2 changes:
    // 1. Guardian (teachers) PII actually auth-gated now (v1 claimed it but
    //    had `allow read: if true`); kid login uses the new /classCodes lookup
    // 2. students/assignments updates require request.auth != null — kids get
    //    invisible anonymous sessions (amgEnsureAnonAuth in oda-core.js)
    // 3. Owning guardian can fix kid identity fields incl. parentCode
    //    (unbreaks parent login for legacy records)
    // 4. Data size limits on user-generated content to prevent DoS
    //
    // KNOWN LIMIT (documented, deferred): the economy is still client-trusted.
    // Anonymous auth + App Check add friction, not proof. True anti-cheat
    // needs Cloud Function-mediated coin awards.
    // ============================================================

    // Helper: check data size to prevent DoS via large payloads
    function isReasonableSize() {
      return request.resource.size() < 1000000; // 1MB max per document
    }

    // Guardians (parents + teachers): PII is auth-gated now.
    // Kid login resolves codes via the thin public /classCodes collection
    // instead of reading guardian docs. (Was: allow read: if true.)
    match /teachers/{teacherId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == teacherId
        && isReasonableSize();
      allow update: if request.auth != null && request.auth.uid == teacherId
        && isReasonableSize();
      allow delete: if request.auth != null && request.auth.uid == teacherId;
    }

    // Thin public lookup: family/class code -> guardian id (no PII).
    // Written by the owning guardian on login (self-healing) or the
    // one-time migration script (tools/migrate-classcodes.mjs).
    match /classCodes/{code} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && isReasonableSize();
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Students: guardians create/delete; progress writes require an auth
    // session (kids ride anonymous auth — see amgEnsureAnonAuth in oda-core.js).
    // SECURITY FIXES vs previous version:
    //  - update now requires request.auth != null (was: fully unauthenticated)
    //  - owning guardian may edit identity fields incl. parentCode (the old
    //    blanket freeze silently broke the parentCode backfill -> parent login)
    match /students/{studentId} {
      allow read: if true;  // kid login name-picker + parent quick-check
      allow create: if request.auth != null && isReasonableSize();
      allow update: if isReasonableSize() && request.auth != null && (
        request.auth.uid == resource.data.teacherId
        || !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['teacherId', 'name', 'grade', 'parentCode'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
    }

    // Assignments/missions: guardians create, kids submit work.
    // SECURITY: update now requires auth (kids use anonymous sessions);
    // kids still can't change teacherId or studentId.
    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if request.auth != null && isReasonableSize();
      allow update: if isReasonableSize()
        && request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['teacherId', 'studentId'])
        && request.resource.data.teacherId is string
        && request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Student work collections: require studentId on create,
    // prevent field injection by validating structure
    // ----------------------------------------------------------

    match /pitchChallenges/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /elevatorPitches/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /lemonadeGroups/{groupId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['studentId', 'teacherId'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /pitchProjects/{projectId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null
        || resource.data.studentId is string;
    }

    // Galleries: size limit + require identity on create
    match /pitchGallery/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentName is string
        && isReasonableSize();
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likes']);
      allow delete: if request.auth != null;
    }

    match /canvasGallery/{artId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['studentId', 'studentName'])
        && isReasonableSize();
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likes']);
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Teacher-managed content: auth required for create/update/delete
    // ----------------------------------------------------------

    match /spellingLists/{listId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /spellingWords/{wordId} {
      allow read: if true;
      allow write: if request.auth != null && isReasonableSize();
    }

    match /jeopardyBoards/{boardId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /flashcardDecks/{deckId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /wordSearchPuzzles/{puzzleId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /crosswordPuzzles/{puzzleId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /libraryPassages/{passageId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /questionBank/{setId} {
      allow read: if true;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Student results: immutable records with validation
    // SECURITY: Results can't be modified after creation (anti-cheating)
    // ----------------------------------------------------------

    match /spellingResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /jeopardyResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && request.resource.data.score is number
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /quizResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /flashcardProgress/{progressId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /flashcardLeaderboard/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /wordSearchResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /crosswordResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /readingProgress/{progressId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if request.resource.data.studentId is string
        && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /readingLogs/{logId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && isReasonableSize();
      allow update: if false;
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Real-time multiplayer games
    // SECURITY: Require identity proof on create, size limits everywhere
    // ----------------------------------------------------------

    match /liveGames/{gameId} {
      allow read: if true;
      allow create: if (request.resource.data.classCode is string
        || request.auth != null)
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /chessGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /connect4games/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /triviaGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'hostId'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Arcade records/leaderboards
    // ----------------------------------------------------------

    match /snakeRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /chessRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /connect4Records/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /connect4Tournaments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'createdBy'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /solitaireRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /2048Records/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /typingRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /hangmanRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /memoryRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /rpsRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /tttRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /triviaRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Checkers games, records, tournaments
    match /checkersGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /checkersRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /checkersTournaments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'teacherId'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // TicTacToe games + tournaments
    match /tttGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /tttTournaments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'createdBy', 'host'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // RPS games + tournaments
    match /rpsGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /rpsTournaments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'createdBy', 'host'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Hangman multiplayer games
    match /hangmanGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['player1', 'hostId'])
        && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true; // Players clean up finished games
    }

    // Typing race games
    match /typingGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['player1', 'hostId']) && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Battleship multiplayer games
    match /battleshipGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true;
    }

    match /battleshipRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Block Blast records
    match /blockblastRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Wordle records
    match /wordleRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Uno multiplayer games
    match /unoGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true;
    }

    match /unoRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // ODA Racers game saves + leaderboard
    match /odaRacers/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /odaRacersLeaderboard/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Lemonade Tycoon game saves + leaderboard
    match /lemonadeGame/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /lemonadeLeaderboard/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Coin Miner saves + records
    match /coinMinerSaves/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /coinMinerRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Misc collections
    // ----------------------------------------------------------

    match /scoreboardGames/{gameId} {
      allow read: if true;
      allow create: if request.auth != null && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /typingStats/{statId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /keyboardStats/{statId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /raffles/{raffleId} {
      allow read: if true;
      allow create: if request.auth != null && isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Feedback: anyone can submit, size-limited, teachers manage
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 2000
        && isReasonableSize();
      allow update, delete: if request.auth != null;
    }

    // Penalty Kick multiplayer games
    match /penaltyKickGames/{docId} {
      allow read: if true;
      allow create: if isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true;
    }

    // New arcade game records
    match /penaltykickRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /flappyRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /bowlingRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /dominoRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /dominoGames/{docId} {
      allow read: if true;
      allow create: if isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true;
    }

    match /suikaRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /fruitninjaRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /pingpongRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /aimtrainerRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /brickbreakerRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /whackamoleRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    match /simonsaysRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Basketball multiplayer games + records
    match /basketballGames/{docId} {
      allow read: if true;
      allow create: if isReasonableSize();
      allow update: if isReasonableSize();
      allow delete: if true;
    }

    match /basketballRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Helicopter records
    match /helicopterRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Dodgeball records
    match /dodgeballRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Sliding puzzle records
    match /slidingpuzzleRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string && isReasonableSize();
      allow update: if request.resource.data.studentId is string && isReasonableSize();
      allow delete: if request.auth != null;
    }

    // Default deny — catches any unmatched collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
