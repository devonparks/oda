rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper: validate student-created data has required identifiers
    // Students don't use Firebase Auth, so we validate data shape
    // instead. Requiring studentId + classCode ties writes to a
    // teacher's ecosystem and blocks anonymous abuse.
    // ============================================================

    // Teachers: public read needed for student class-code lookup
    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == teacherId;
    }

    // Students: teachers create, students can update limited fields
    match /students/{studentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherId', 'name'])
        && request.resource.data.teacherId is string;
      allow delete: if request.auth != null;
    }

    // Assignments: teachers create, students submit work
    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherId', 'studentId'])
        && request.resource.data.teacherId is string
        && request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Student work collections: require studentId on create,
    // prevent field injection by validating structure
    // ----------------------------------------------------------

    // Pitch Challenges
    match /pitchChallenges/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // Elevator Pitches
    match /elevatorPitches/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // Lemonade Groups
    match /lemonadeGroups/{groupId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['studentId', 'teacherId']);
      allow update: if true;  // Group members join/update collaboratively
      allow delete: if request.auth != null;
    }

    // Pitch Projects: student saves in progress
    match /pitchProjects/{projectId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // Pitch Gallery: community sharing with likes
    match /pitchGallery/{pitchId} {
      allow read: if true;
      allow create: if request.resource.data.studentName is string;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likes']);
      allow delete: if request.auth != null;
    }

    // Canvas Gallery: student art with likes
    match /canvasGallery/{artId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['studentId', 'studentName']);
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likes']);
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Teacher-managed content: auth required for create/update/delete
    // ----------------------------------------------------------

    match /spellingLists/{listId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /spellingWords/{wordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /jeopardyBoards/{boardId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /flashcardDecks/{deckId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /wordSearchPuzzles/{puzzleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /crosswordPuzzles/{puzzleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /libraryPassages/{passageId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /questionBank/{setId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Student results: require studentId + score validation
    // ----------------------------------------------------------

    match /spellingResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && request.resource.data.score is number;
      allow update: if false;  // Results are immutable
      allow delete: if request.auth != null;
    }

    match /jeopardyResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string
        && request.resource.data.score is number;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /quizResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /flashcardProgress/{progressId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /flashcardLeaderboard/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /wordSearchResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /crosswordResults/{resultId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /readingProgress/{progressId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /readingLogs/{logId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Real-time multiplayer games: need open write for game state
    // but require classCode to tie to a teacher's class
    // ----------------------------------------------------------

    match /liveGames/{gameId} {
      allow read: if true;
      allow create: if request.resource.data.classCode is string
        || request.auth != null;
      allow update: if true;  // Real-time game state updates
      allow delete: if request.auth != null;
    }

    match /chessGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string;
      allow update: if true;  // Real-time game moves
      allow delete: if request.auth != null;
    }

    match /connect4games/{docId} {
      allow read: if true;
      allow create: if request.resource.data.player1 is string;
      allow update: if true;  // Real-time game moves
      allow delete: if request.auth != null;
    }

    match /triviaGames/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'hostId']);
      allow update: if true;  // Real-time game state
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Arcade records/leaderboards: require studentId, validate scores
    // ----------------------------------------------------------

    match /snakeRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /chessRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /connect4Records/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /connect4Tournaments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['classCode', 'createdBy']);
      allow update: if true;  // Tournament state updates
      allow delete: if request.auth != null;
    }

    match /solitaireRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /2048Records/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /typingRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /hangmanRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /memoryRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /rpsRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /tttRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    match /triviaRecords/{docId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // ----------------------------------------------------------
    // Misc student collections
    // ----------------------------------------------------------

    match /scoreboardGames/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;  // Teachers create games
      allow update: if true;  // Students update scores during game
      allow delete: if request.auth != null;
    }

    match /typingStats/{statId} {
      allow read: if true;
      allow create: if request.resource.data.studentId is string;
      allow update: if request.resource.data.studentId is string;
      allow delete: if request.auth != null;
    }

    // Raffles: teachers create, students buy entries
    match /raffles/{raffleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;  // Students buy entries, teacher draws
      allow delete: if request.auth != null;
    }

    // Feedback: anyone can submit, teachers manage
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 2000;
      allow update, delete: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
