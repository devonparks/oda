rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teachers: public read needed for student class-code lookup
    match /teachers/{teacherId} {
      allow read: if true;  // Students query by classCode without auth
      allow create: if request.auth != null && request.auth.uid == teacherId;
      allow update, delete: if request.auth != null && request.auth.uid == teacherId;
    }

    // Students: teachers can manage their students, students can read their own data
    match /students/{studentId} {
      allow read: if true;  // Students need to read without auth (class code login)
      allow create: if request.auth != null;  // Only teachers create students
      // Students can update their own data (coins, arcade) but not reassign themselves
      allow update: if true
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherId']);
      allow delete: if request.auth != null;  // Only teachers delete
    }

    // Assignments: readable by the student assigned, writable by teacher
    match /assignments/{assignmentId} {
      allow read: if true;  // Students read without Firebase Auth
      allow create: if request.auth != null;  // Teachers create
      // Students can submit work but not change teacherId or studentId
      allow update: if true
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherId', 'studentId']);
      allow delete: if request.auth != null;  // Teachers delete
    }

    // Pitch Challenges: student creates, teacher reads for grading
    match /pitchChallenges/{pitchId} {
      allow read: if true;
      allow write: if true;  // Students save pitches without Firebase Auth
    }

    // Elevator Pitches: same pattern
    match /elevatorPitches/{pitchId} {
      allow read: if true;
      allow write: if true;
    }

    // Lemonade Groups: students create groups, teachers approve
    match /lemonadeGroups/{groupId} {
      allow read: if true;
      allow write: if true;
    }

    // Spelling Lists: teachers create, students read
    match /spellingLists/{listId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Spelling Results: students write results, teachers read
    match /spellingResults/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // Pitch Gallery: community sharing
    match /pitchGallery/{pitchId} {
      allow read: if true;
      allow create: if true;  // Students share pitches
      allow update: if true;  // Like counts
      allow delete: if request.auth != null;  // Only teachers delete
    }

    // Pitch Projects: student pitch saves synced to cloud
    match /pitchProjects/{projectId} {
      allow read: if true;
      allow write: if true;
    }

    // Spelling Words: teacher-managed word lists
    match /spellingWords/{wordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Jeopardy boards and results
    match /jeopardyBoards/{boardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /jeopardyResults/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // Quiz Blitz (Kahoot) quizzes, live games, and results
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /liveGames/{gameId} {
      allow read: if true;
      allow write: if true;  // Real-time multiplayer needs open write
    }
    match /quizResults/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // Flashcard decks and progress
    match /flashcardDecks/{deckId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /flashcardProgress/{progressId} {
      allow read: if true;
      allow write: if true;
    }

    // Word Search puzzles and results
    match /wordSearchPuzzles/{puzzleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /wordSearchResults/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // Crossword puzzles and results
    match /crosswordPuzzles/{puzzleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /crosswordResults/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // Library passages, reading progress, and logs
    match /libraryPassages/{passageId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /readingProgress/{progressId} {
      allow read: if true;
      allow write: if true;
    }
    match /readingLogs/{logId} {
      allow read: if true;
      allow write: if true;
    }

    // Canvas gallery
    match /canvasGallery/{artId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;  // Likes
      allow delete: if request.auth != null;
    }

    // Raffles
    match /raffles/{raffleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;  // Students buy entries, teacher draws
      allow delete: if request.auth != null;
    }

    // Scoreboard games
    match /scoreboardGames/{gameId} {
      allow read: if true;
      allow write: if true;
    }

    // Keyboard Warriors stats
    match /typingStats/{statId} {
      allow read: if true;
      allow write: if true;
    }

    // Arcade game records and leaderboards (students save scores without auth)
    match /snakeRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /chessGames/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /chessRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /connect4games/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /connect4Records/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /connect4Tournaments/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /solitaireRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /2048Records/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /typingRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /hangmanRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /memoryRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /rpsRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /tttRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /triviaGames/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /triviaRecords/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /flashcardLeaderboard/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Shared question bank (used across Jeopardy, Kahoot, Flashcards)
    match /questionBank/{setId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Feedback: students submit, admins/teachers read and manage
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if true;  // Students submit feedback without auth
      allow update, delete: if request.auth != null;
    }

    // Templates: teachers save and load assignment templates
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
