rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public educational videos (Mikaila Ulmer, etc.) - anyone can read
    match /videos/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Student pitch/elevator videos - require auth to write, allow read for grading
    match /student-videos/{allPaths=**} {
      allow read;
      allow write: if request.auth != null
                    && request.resource.size < 100 * 1024 * 1024
                    && request.resource.contentType.matches('video/.*');
    }

    // Default: require authentication
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
